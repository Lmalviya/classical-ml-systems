                "# ─── CELL 3: Sample Eigenvalue Bias — N/d Ratio Effect ────────────────────────\n",
                "import numpy as np\n",
                "import matplotlib.pyplot as plt\n",
                "\n",
                "# True population covariance: identity (no structure)\n",
                "# Any spread in sample eigenvalues is pure finite-sample bias\n",
                "np.random.seed(42)\n",
                "\n",
                "d = 100  # fixed dimensionality\n",
                "N_values = [30, 50, 100, 200, 500, 2000]\n",
                "\n",
                "fig, axes = plt.subplots(2, 3, figsize=(15, 9))\n",
                "axes = axes.flatten()\n",
                "\n",
                "lambda_vals_plot = np.linspace(0, 6, 500)\n",
                "\n",
                "for ax, N in zip(axes, N_values):\n",
                "    gamma = d / N\n",
                "    # Generate pure noise (true cov = I)\n",
                "    X_noise = np.random.randn(N, d)\n",
                "    X_noise = X_noise - X_noise.mean(axis=0)\n",
                "    _, s, _ = np.linalg.svd(X_noise, full_matrices=False)\n",
                "    sample_evals = s**2 / N\n",
                "    sample_evals = sample_evals[:d]  # max d eigenvalues\n",
                "\n",
                "    sigma2 = 1.0\n",
                "    lambda_plus  = sigma2 * (1 + np.sqrt(gamma))**2\n",
                "    lambda_minus = sigma2 * max(0, (1 - np.sqrt(gamma)))**2\n",
