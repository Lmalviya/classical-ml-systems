                "# ─── CELL 2: Marchenko-Pastur Law — Signal Detection ──────────────────────────\n",
                "import numpy as np\n",
                "import matplotlib.pyplot as plt\n",
                "\n",
                "def marchenko_pastur_pdf(lambda_vals, gamma, sigma2=1.0):\n",
                "    \"\"\"Marchenko-Pastur probability density function.\"\"\"\n",
                "    lambda_plus  = sigma2 * (1 + np.sqrt(gamma))**2\n",
                "    lambda_minus = sigma2 * (1 - np.sqrt(gamma))**2\n",
                "    pdf = np.zeros_like(lambda_vals)\n",
                "    mask = (lambda_vals >= lambda_minus) & (lambda_vals <= lambda_plus)\n",
                "    lv = lambda_vals[mask]\n",
                "    pdf[mask] = (np.sqrt((lambda_plus - lv) * (lv - lambda_minus))\n",
                "                 / (2 * np.pi * sigma2 * gamma * lv))\n",
                "    return pdf, lambda_plus, lambda_minus\n",
                "\n",
                "np.random.seed(0)\n",
                "N, d = 200, 1000           # ratio gamma = d/N = 5\n",
                "sigma2_true = 1.0\n",
                "k_signal = 4               # true signal PCs\n",
                "signal_strengths = [10, 7, 5, 3]  # eigenvalues above noise threshold\n",
                "\n",
                "# Generate data: k_signal strong PCs + noise\n",
                "W = np.random.randn(d, k_signal)\n",
                "Z = np.random.randn(N, k_signal) * np.sqrt(signal_strengths)\n",
                "X_clean = Z @ W.T\n",
                "X_noise = np.sqrt(sigma2_true) * np.random.randn(N, d)\n",
                "X = X_clean + X_noise\n",
                "X = X - X.mean(axis=0)\n",
                "\n",
                "# Sample covariance eigenvalues\n",
                "# Use SVD for efficiency\n",
                "_, s, _ = np.linalg.svd(X, full_matrices=False)\n",
                "sample_eigenvalues = s**2 / N  # eigenvalues of Sigma = X^T X / N\n",
                "\n",
                "# Marchenko-Pastur paramters\n",
                "gamma = d / N\n",
                "lambda_vals = np.linspace(0, sample_eigenvalues.max() * 0.5, 1000)\n",
                "mp_pdf, lambda_plus, lambda_minus = marchenko_pastur_pdf(lambda_vals, gamma, sigma2_true)\n",
                "\n",
                "# Estimate noise threshold\n",
                "print(f\"N={N}, d={d}, gamma=d/N={gamma:.1f}\")\n",
                "print(f\"Marchenko-Pastur bounds: [{lambda_minus:.3f}, {lambda_plus:.3f}]\")\n",
                "print(f\"True signal strengths (+ noise variance):\")\n",
                "for i, s_val in enumerate(signal_strengths):\n",
                "    print(f\"  PC{i+1}: true λ = {s_val + sigma2_true:.2f}  (signal={s_val} + noise={sigma2_true})\")\n",
                "n_signal = np.sum(sample_eigenvalues > lambda_plus)\n",
                "print(f\"\\nEigenvalues above λ_+ (detected as signal): {n_signal}  (true: {k_signal})\")\n",
                "\n",
                "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 6))\n",
                "\n",
                "# Left: eigenvalue spectrum with MP overlay\n",
                "bins = np.linspace(0, 6, 80)\n",
                "ax1.hist(sample_eigenvalues[sample_eigenvalues <= 6], bins=bins, density=True,\n",
                "         color='steelblue', alpha=0.6, label='Sample eigenvalues (bulk noise)')\n",
                "# Signal eigenvalues separately\n",
                "sig_evals = sample_eigenvalues[sample_eigenvalues > lambda_plus]\n",
                "for ev in sig_evals:\n",
                "    ax1.axvline(ev, color='red', lw=1.5, alpha=0.8)\n",
                "ax1.axvline(sig_evals[0], color='red', lw=1.5, label=f'Signal eigenvalues ({len(sig_evals)} detected)')\n",
                "ax1.plot(lambda_vals, mp_pdf, 'k-', lw=2.5, label='Marchenko-Pastur density')\n",
                "ax1.axvline(lambda_plus, color='orange', ls='--', lw=2, label=f'λ+ = {lambda_plus:.2f} (noise threshold)')\n",
                "ax1.set_xlabel('Eigenvalue λ', fontsize=11); ax1.set_ylabel('Density', fontsize=11)\n",
                "ax1.set_title('Marchenko-Pastur Law: Separating Signal from Noise', fontsize=11)\n",
                "ax1.legend(fontsize=9); ax1.grid(alpha=0.3)\n",
                "\n",
                "# Right: all eigenvalues on log scale\n",
                "ax2.semilogy(range(1, N+1), sorted(sample_eigenvalues, reverse=True), 'o-', markersize=4, color='steelblue')\n",
                "ax2.axhline(lambda_plus, color='orange', ls='--', lw=2, label=f'MP threshold λ+ = {lambda_plus:.2f}')\n",
                "ax2.axvspan(0, n_signal + 0.5, alpha=0.1, color='red', label=f'Signal region ({n_signal} PCs)')\n",
                "ax2.set_xlabel('PC rank', fontsize=11); ax2.set_ylabel('Eigenvalue (log scale)', fontsize=11)\n",
                "ax2.set_title('Ordered Eigenvalues: Signal Above MP Threshold', fontsize=11)\n",
                "ax2.legend(fontsize=9); ax2.grid(alpha=0.3, which='both')\n",
                "\n",
                "plt.suptitle('Marchenko-Pastur Law for Signal Detection in High-Dimensional PCA', \n",
                "             fontsize=13, fontweight='bold')\n",
                "plt.tight_layout(); plt.show()"
            ]
        },
