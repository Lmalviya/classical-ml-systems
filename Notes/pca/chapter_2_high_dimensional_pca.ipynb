                "    ax.axvline(1.0, color='green', ls='--', lw=2, label='True λ=1 (identity cov)')\n",
                "    ax.set_title(f'N={N}, d={d}, γ={gamma:.1f}\\nλ_max_noise={lambda_plus:.2f}', fontsize=10)\n",
